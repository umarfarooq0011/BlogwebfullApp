# Frontend uses a relative '/api' baseURL in src/utils/axiosInstance.js,
# so no env vars are required for the production build (the API is
# served from the same origin as the static frontend).
#
# In local dev, vite.config.js proxies /api -> http://localhost:8080.
# Add VITE_* variables here only if frontend code starts reading them
# (see https://vite.dev/guide/env-and-mode for the VITE_ prefix rule).
